# .gitignore

# Зависимости
node_modules/
backend/node_modules/
frontend/node_modules/

# Файлы окружения
.env
backend/.env
frontend/.env
*.env.local
*.env.development
*.env.production

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# База данных (если не хотите загружать данные)
backend/db/*.db
backend/db/*.db-journal

# Системные файлы
.DS_Store
Thumbs.db
desktop.ini

# Редакторы кода
.vscode/
.idea/
*.swp
*.swo
*~

# Сборки
backend/uploads/
frontend/build/
frontend/dist/

# Временные файлы
*.tmp
*.temp
.cache/